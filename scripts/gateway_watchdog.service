[Unit]
Description=AIoT Edge Gateway Watchdog
After=network.target

[Service]
Type=simple
ExecStart=/mnt/ssd/GitHub/aiot-edge-gateway/build/gateway_watchdog/gateway_watchdog
WorkingDirectory=/mnt/ssd/GitHub/aiot-edge-gateway
User=ubuntu
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
